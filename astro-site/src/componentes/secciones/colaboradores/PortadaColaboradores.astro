---
import Antetitulo from '@componentes/ui/Antetitulo.astro';
import AdornoNeo from '@componentes/ui/AdornoNeo.astro';

interface Props {
  total: number;
}
const { total } = Astro.props;
const totalFormateado = String(total).padStart(2, '0');
---

<section class="portada-colaboradores">
  <div class="portada-colaboradores__contenido">
    <AdornoNeo pieza="04" ancho="280px" abajo="-80px" derecha="-70px" opacidad="0.08" />

    <Antetitulo tono="contorno">Colaboradores</Antetitulo>
    <h1 class="portada-colaboradores__titulo">Las organizaciones que ya confían en nosotros.</h1>
    <p class="portada-colaboradores__subtitulo">
      Trabajamos con empresas de distintos sectores acompañando su crecimiento con herramientas
      que evolucionan junto a ellas.
    </p>
  </div>
  <div class="portada-colaboradores__panel">
    <AdornoNeo pieza="16" ancho="260px" arriba="-70px" derecha="-60px" opacidad="0.35" />

    <p class="portada-colaboradores__conteo">{totalFormateado}</p>
    <p class="portada-colaboradores__etiqueta">Colaboradores</p>
  </div>
</section>

<style>
  .portada-colaboradores {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    border-bottom: var(--borde-base);
  }

  .portada-colaboradores__contenido {
    position: relative;
    overflow: hidden;
    background: var(--color-tinta);
    color: var(--color-fondo);
    padding: 5.25rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.375rem;
  }

  .portada-colaboradores__titulo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1.02;
    letter-spacing: -1.5px;
    max-width: 36rem;
    margin: 0;
  }

  .portada-colaboradores__subtitulo {
    font-size: 1.0625rem;
    max-width: 520px;
    opacity: 0.7;
    line-height: 1.6;
    margin: 0;
  }

  .portada-colaboradores__panel {
    position: relative;
    overflow: hidden;
    background: var(--color-principal);
    border-left: var(--borde-base);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 2.75rem;
    min-height: 21.25rem;
  }

  .portada-colaboradores__conteo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: 7.5rem;
    line-height: 1;
    letter-spacing: -4px;
    color: var(--color-tinta);
    margin: 0;
  }

  .portada-colaboradores__etiqueta {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-tinta);
    margin: 0;
  }

  @media (max-width: 768px) {
    .portada-colaboradores {
      grid-template-columns: 1fr;
    }
    .portada-colaboradores__panel {
      border-left: none;
      border-top: var(--borde-base);
    }
  }
</style>
