---
import Boton from '@componentes/ui/Boton.astro';
import AdornoNeo from '@componentes/ui/AdornoNeo.astro';
---

<section class="vitrina seccion">
  <div class="vitrina__rejilla">
    <div class="vitrina__pila">
      <div class="vitrina__bloque vitrina__bloque--alto">
        <AdornoNeo pieza="05" ancho="220px" arriba="-50px" derecha="-40px" opacidad="0.45" />
      </div>
      <div class="vitrina__bloque vitrina__bloque--bajo">
        <AdornoNeo pieza="12" ancho="200px" abajo="-50px" izquierda="-40px" opacidad="0.6" />
      </div>
    </div>
    <div class="vitrina__tarjeta">
      <p class="vitrina__antetitulo">Con quién trabajamos</p>
      <h2 class="vitrina__titulo">Proyectos en salud, medio ambiente y sector público.</h2>
      <p class="vitrina__cuerpo">
        Acompañamos a cada cliente con herramientas que evolucionan junto a su operación, desde
        software hospitalario hasta el observatorio ambiental de Barranquilla.
      </p>
      <Boton ruta="/colaboradores" tono="principal" tamano="sm">Ver colaboradores</Boton>
    </div>
  </div>
</section>

<style>
  .vitrina {
    background: var(--color-blanco);
  }

  .vitrina__rejilla {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 1100px;
    margin-inline: auto;
    align-items: center;
  }

  .vitrina__pila {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .vitrina__bloque {
    position: relative;
    overflow: hidden;
    border: var(--borde-base);
    box-shadow: var(--sombra-md);
  }
  .vitrina__bloque--alto {
    background: var(--color-principal);
    height: 260px;
  }
  .vitrina__bloque--bajo {
    background: var(--color-gris);
    height: 180px;
    margin-left: 3rem;
  }

  .vitrina__tarjeta {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    background: var(--color-fondo);
    border: var(--borde-base);
    box-shadow: var(--sombra-lg);
    padding: 2.25rem;
  }

  .vitrina__antetitulo {
    font-weight: var(--peso-negrita);
    font-size: var(--texto-xs);
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-principal);
    margin: 0;
  }

  .vitrina__titulo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-h5);
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin: 0;
  }

  .vitrina__cuerpo {
    font-size: var(--texto-sm);
    opacity: 0.75;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .vitrina__rejilla {
      grid-template-columns: 1fr;
    }
    .vitrina__bloque--bajo {
      margin-left: 0;
    }
  }
</style>
