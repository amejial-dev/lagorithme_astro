---
interface Elemento {
  etiqueta: string;
  titulo: string;
  cuerpo: string;
}
interface Props {
  mision: Elemento;
  vision: Elemento;
}
const { mision, vision } = Astro.props;
const elementos = [mision, vision];
---

<div class="rejilla-mv">
  {
    elementos.map((elemento) => (
      <div class="tarjeta-mv">
        <div class="tarjeta-mv__icono">
          <img src="/assets/icons/bookmark.svg" alt="" width="26" height="26" />
        </div>
        <p class="tarjeta-mv__etiqueta">{elemento.etiqueta}</p>
        <h3 class="tarjeta-mv__titulo">{elemento.titulo}</h3>
        <p class="tarjeta-mv__cuerpo">{elemento.cuerpo}</p>
      </div>
    ))
  }
</div>

<style>
  .rejilla-mv {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem;
    max-width: 1100px;
    width: 100%;
  }

  .tarjeta-mv {
    border: var(--borde-base);
    background: var(--color-principal);
    color: var(--color-tinta);
    box-shadow: var(--sombra-lg);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tarjeta-mv__icono {
    width: 3.25rem;
    height: 3.25rem;
    border: var(--borde-fino);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tarjeta-mv__etiqueta {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: 0.9375rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }

  .tarjeta-mv__titulo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: 1.625rem;
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin: 0;
  }

  .tarjeta-mv__cuerpo {
    font-size: 0.9375rem;
    opacity: 0.8;
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 768px) {
    .rejilla-mv {
      grid-template-columns: 1fr;
    }
  }
</style>
