---
import type { ElementoTarjeta } from '@tipos/tarjetas';

interface Props {
  elementos: ElementoTarjeta[];
  columnas?: 2 | 3 | 4;
  tonoSombra?: 'tinta' | 'principal';
  grosorBorde?: 'base' | 'grueso';
  disposicion?: 'rejilla' | 'flujo';
}

const {
  elementos,
  columnas = 3,
  tonoSombra = 'tinta',
  grosorBorde = 'grueso',
  disposicion = 'rejilla',
} = Astro.props;
---

<div
  class={disposicion === 'flujo'
    ? 'rejilla-tarjetas rejilla-tarjetas--flujo'
    : `rejilla-tarjetas rejilla-tarjetas--${columnas}`}
>
  {
    elementos.map((elemento) => (
      <div
        class={`tarjeta-icono tarjeta-icono--${tonoSombra} tarjeta-icono--${grosorBorde}`}
        style={`--tarjeta-fondo:${elemento.fondo ?? 'var(--color-fondo)'}; --tarjeta-texto:${elemento.texto ?? 'var(--color-tinta)'};`}
      >
        <div
          class="tarjeta-icono__insignia"
          style={elemento.insignia.fondo ? `--insignia-fondo:${elemento.insignia.fondo}` : ''}
        >
          {elemento.insignia.tipo === 'icono' ? (
            <img src={elemento.insignia.valor} alt="" width="26" height="26" />
          ) : (
            <span class="tarjeta-icono__numero">{elemento.insignia.valor}</span>
          )}
        </div>
        <h3 class="tarjeta-icono__titulo">{elemento.titulo}</h3>
        <p class="tarjeta-icono__cuerpo">{elemento.cuerpo}</p>
      </div>
    ))
  }
</div>

<style>
  .rejilla-tarjetas {
    display: grid;
    gap: 1.625rem;
    max-width: var(--contenedor-max);
    width: 100%;
    margin-inline: auto;
  }
  .rejilla-tarjetas--2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .rejilla-tarjetas--3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .rejilla-tarjetas--4 {
    grid-template-columns: repeat(4, 1fr);
  }
  .rejilla-tarjetas--flujo {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }
  .rejilla-tarjetas--flujo .tarjeta-icono {
    flex: 1 1 320px;
    max-width: 360px;
  }
  @media (max-width: 992px) {
    .rejilla-tarjetas--2,
    .rejilla-tarjetas--3,
    .rejilla-tarjetas--4 {
      grid-template-columns: 1fr;
    }
  }

  .tarjeta-icono {
    background: var(--tarjeta-fondo);
    color: var(--tarjeta-texto);
    padding: 1.875rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: translate var(--transicion-hover), box-shadow var(--transicion-hover);
    translate: 0 0;
  }

  .tarjeta-icono--base {
    border: var(--borde-base);
  }
  .tarjeta-icono--grueso {
    border: var(--borde-grueso);
  }

  .tarjeta-icono--tinta {
    box-shadow: var(--sombra-lg);
  }
  .tarjeta-icono--tinta:hover {
    translate: -4px -4px;
    box-shadow: var(--sombra-lg-hover);
  }
  .tarjeta-icono--principal {
    box-shadow: 8px 8px 0 var(--color-principal);
  }
  .tarjeta-icono--principal:hover {
    translate: -4px -4px;
    box-shadow: 12px 12px 0 var(--color-principal);
  }

  .tarjeta-icono__insignia {
    width: 3.5rem;
    height: 3.5rem;
    border: var(--borde-base);
    background: var(--insignia-fondo, var(--color-principal));
    color: var(--color-tinta);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--sombra-sm);
  }

  .tarjeta-icono__numero {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: 1.5rem;
  }

  .tarjeta-icono__titulo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: 1.3125rem;
    line-height: 1.1;
    margin: 0;
  }

  .tarjeta-icono__cuerpo {
    font-size: 0.875rem;
    opacity: 0.8;
    line-height: 1.6;
    margin: 0;
  }
</style>
