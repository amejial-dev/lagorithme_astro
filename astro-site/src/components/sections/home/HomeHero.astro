---
import Button from '@components/ui/Button.astro';
---

<section class="home-hero section">
  <img
    src="/assets/images/hero-pattern.svg"
    alt=""
    class="home-hero__deco home-hero__deco--left"
  />
  <img
    src="/assets/images/hero-decoration-shape.svg"
    alt=""
    class="home-hero__deco home-hero__deco--right"
  />

  <h1 class="home-hero__title">Lorem ipsum dolor sit amet, consectetur adipiscing.</h1>
  <p class="home-hero__subtitle">
    Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque
    laudantium, totam rem aperiam eaque ipsa.
  </p>
  <Button href="/contacto" variant="solid" tone="coral" size="lg">
    Comenzar ahora — es gratis
  </Button>
  <p class="home-hero__note">Lorem ipsum, no se requiere tarjeta · cancela cuando quieras</p>
</section>

<style>
  .home-hero {
    background: var(--color-bg);
    color: var(--color-ink);
    padding-top: clamp(3.5rem, 8vw, 4.375rem);
    padding-bottom: clamp(4rem, 10vw, 6.25rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.625rem;
    position: relative;
    overflow: hidden;
  }

  .home-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: clamp(2.25rem, 6vw, 4.25rem);
    line-height: 1.03;
    letter-spacing: -1.5px;
    max-width: 920px;
    margin: 0;
    position: relative;
  }

  .home-hero__subtitle {
    font-size: 1.1875rem;
    max-width: 620px;
    opacity: 0.7;
    line-height: 1.55;
    margin: 0;
    position: relative;
  }

  .home-hero__note {
    font-size: 0.8125rem;
    opacity: 0.55;
    letter-spacing: 0.3px;
    margin: 0;
    position: relative;
  }

  .home-hero__deco {
    position: absolute;
    pointer-events: none;
  }
  .home-hero__deco--left {
    left: 5%;
    top: 46%;
    width: 224px;
  }
  .home-hero__deco--right {
    left: 75%;
    top: 30%;
    width: 379px;
  }

  @media (max-width: 768px) {
    .home-hero__deco {
      display: none;
    }
  }
</style>
