---
import type { SimpleCard } from '@data/home';

interface Props {
  items: SimpleCard[];
}
const { items } = Astro.props;
---

<div class="cards4">
  {
    items.map((item) => (
      <div class="cards4__item" style={`--rotate:${item.rotate}deg;`}>
        <h3 class="cards4__title">{item.title}</h3>
        <p class="cards4__body">{item.body}</p>
      </div>
    ))
  }
</div>

<style>
  .cards4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: var(--container-max);
    width: 100%;
  }

  .cards4__item {
    border: var(--border-base);
    background: var(--color-bg);
    box-shadow: var(--shadow-md);
    padding: 1.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    transform: rotate(var(--rotate));
  }
  .cards4__item:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: var(--shadow-md-hover);
  }

  .cards4__title {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 1rem;
    margin: 0;
  }

  .cards4__body {
    font-size: 0.8125rem;
    line-height: 1.55;
    opacity: 0.75;
    margin: 0;
  }

  @media (max-width: 992px) {
    .cards4 {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
