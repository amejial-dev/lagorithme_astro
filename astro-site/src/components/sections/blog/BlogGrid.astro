---
import type { BlogPost } from '@data/blog';
import Button from '@components/ui/Button.astro';

interface Props {
  posts: BlogPost[];
}
const { posts } = Astro.props;
---

<div class="blog-grid">
  {
    posts.map((post) => (
      <a href="#" class="blog-card">
        <div class="blog-card__image" style={`background:${post.imgBg};`} />
        <div class="blog-card__body">
          <div class="blog-card__meta">
            <span class="blog-card__tag">{post.tag}</span>
            <span class="blog-card__date">{post.date}</span>
          </div>
          <h3 class="blog-card__title">{post.title}</h3>
          <p class="blog-card__excerpt">{post.excerpt}</p>
        </div>
      </a>
    ))
  }
</div>

<div class="blog-grid__more">
  <Button tone="coral" size="md">Cargar más artículos</Button>
</div>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    max-width: var(--container-max);
    width: 100%;
  }

  .blog-card {
    text-decoration: none;
    color: var(--color-ink);
    border: var(--border-base);
    background: var(--color-bg);
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition: translate var(--ease-hover), box-shadow var(--ease-hover);
    translate: 0 0;
  }
  .blog-card:hover {
    translate: -3px -3px;
    box-shadow: var(--shadow-md-hover);
    color: var(--color-ink);
  }

  .blog-card__image {
    height: 170px;
    border-bottom: var(--border-base);
  }

  .blog-card__body {
    padding: 1.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .blog-card__tag {
    border: var(--border-thin);
    background: var(--color-coral);
    color: var(--color-ink);
    font-size: 0.6875rem;
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    padding: 0.1875rem 0.625rem;
  }
  .blog-card__date {
    font-size: 0.75rem;
    opacity: 0.5;
  }

  .blog-card__title {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 1.1875rem;
    line-height: 1.2;
    margin: 0;
  }

  .blog-card__excerpt {
    font-size: 0.875rem;
    opacity: 0.7;
    line-height: 1.55;
    margin: 0;
  }

  .blog-grid__more {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 992px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
