---
import Eyebrow from '@components/ui/Eyebrow.astro';
---

<section class="team-hero">
  <div class="team-hero__content">
    <Eyebrow tone="outline">Colaboradores</Eyebrow>
    <h1 class="team-hero__title">Las personas detrás de Lagorithme.</h1>
    <p class="team-hero__subtitle">
      Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque
      laudantium totam rem aperiam.
    </p>
  </div>
  <div class="team-hero__panel">
    <p class="team-hero__count">03</p>
    <p class="team-hero__label">Colaboradores</p>
  </div>
</section>

<style>
  .team-hero {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    border-bottom: var(--border-base);
  }

  .team-hero__content {
    background: var(--color-ink);
    color: var(--color-bg);
    padding: 5.25rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.375rem;
  }

  .team-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1.02;
    letter-spacing: -1.5px;
    margin: 0;
  }

  .team-hero__subtitle {
    font-size: 1.0625rem;
    max-width: 520px;
    opacity: 0.7;
    line-height: 1.6;
    margin: 0;
  }

  .team-hero__panel {
    background: var(--color-coral);
    border-left: var(--border-base);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 2.75rem;
    min-height: 21.25rem;
  }

  .team-hero__count {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 7.5rem;
    line-height: 1;
    letter-spacing: -4px;
    color: var(--color-ink);
    margin: 0;
  }

  .team-hero__label {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-ink);
    margin: 0;
  }

  @media (max-width: 768px) {
    .team-hero {
      grid-template-columns: 1fr;
    }
    .team-hero__panel {
      border-left: none;
      border-top: var(--border-base);
    }
  }
</style>
