---
import Eyebrow from '@components/ui/Eyebrow.astro';
import Button from '@components/ui/Button.astro';
---

<section class="product-hero">
  <div class="product-hero__content">
    <Eyebrow>Producto</Eyebrow>
    <h1 class="product-hero__title">
      Lorem ipsum dolor sit amet consectetur adipiscing elit.
    </h1>
    <p class="product-hero__subtitle">
      Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque
      laudantium.
    </p>
    <Button href="/contacto" variant="solid" tone="coral" size="lg">Empezar ahora</Button>
  </div>
  <div class="product-hero__media"></div>
</section>

<style>
  .product-hero {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    border-bottom: var(--border-base);
  }

  .product-hero__content {
    padding: 4.375rem 3.5rem 4.375rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.375rem;
  }

  .product-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -1.5px;
    margin: 0;
  }

  .product-hero__subtitle {
    font-size: 1.0625rem;
    max-width: 480px;
    opacity: 0.7;
    line-height: 1.6;
    margin: 0;
  }

  .product-hero__media {
    position: relative;
    border-left: var(--border-base);
    background: var(--color-ink);
    min-height: 27.5rem;
  }

  @media (max-width: 768px) {
    .product-hero {
      grid-template-columns: 1fr;
    }
    .product-hero__media {
      border-left: none;
      border-top: var(--border-base);
      min-height: 220px;
    }
  }
</style>
