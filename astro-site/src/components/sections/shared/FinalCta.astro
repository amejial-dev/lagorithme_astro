---
import Button from '@components/ui/Button.astro';

interface Props {
  title: string;
  subtitle: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title,
  subtitle,
  primaryLabel,
  primaryHref,
  secondaryLabel = 'Hablar con ventas',
  secondaryHref = '/contacto',
} = Astro.props;
---

<section class="final-cta section">
  <h2 class="final-cta__title">{title}</h2>
  <p class="final-cta__subtitle">{subtitle}</p>
  <div class="final-cta__actions">
    {
      primaryLabel && primaryHref && (
        <Button href={primaryHref} variant="solid" tone="coral" size="lg">
          {primaryLabel}
        </Button>
      )
    }
    <Button href={secondaryHref} variant="outline" tone="ink" size="md">
      {secondaryLabel}
    </Button>
  </div>
</section>

<style>
  .final-cta {
    background: var(--color-ink);
    color: var(--color-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.375rem;
    padding-top: 6.25rem;
    padding-bottom: 6.25rem;
  }

  .final-cta__title {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: clamp(1.9rem, 4vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -1px;
    max-width: 760px;
    margin: 0;
  }

  .final-cta__subtitle {
    font-size: 1.0625rem;
    opacity: 0.7;
    max-width: 520px;
    margin: 0;
  }

  .final-cta__actions {
    display: flex;
    gap: 1.125rem;
    margin-top: 0.625rem;
  }
</style>
