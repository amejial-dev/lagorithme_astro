---
import Button from '@components/ui/Button.astro';

const details = [
  { label: 'Correo', value: 'hola@lagorithme.com' },
  { label: 'Teléfono', value: '+00 000 000 000' },
  { label: 'Oficina', value: 'Calle Lorem Ipsum 123<br />Dolor, Sit Amet' },
];

const socials = [
  { label: 'Instagram', icon: '/assets/social/instagram.svg' },
  { label: 'Facebook', icon: '/assets/social/facebook.svg' },
  { label: 'X', icon: '/assets/social/x.svg' },
  { label: 'LinkedIn', icon: '/assets/social/linkedin.svg' },
  { label: 'WhatsApp', icon: '/assets/social/whatsapp.svg' },
  { label: 'YouTube', icon: '/assets/social/youtube.svg' },
];
---

<section class="contact-form">
  <!-- No backend is wired up yet: point this form's action at your
       form-handling endpoint (Formspree, a serverless function, etc). -->
  <form class="contact-form__form">
    <div class="field">
      <label for="name">Nombre</label>
      <input class="field__input" id="name" name="name" type="text" placeholder="Lorem Ipsum" required />
    </div>
    <div class="field">
      <label for="email">Correo electrónico</label>
      <input
        class="field__input"
        id="email"
        name="email"
        type="email"
        placeholder="lorem@ipsum.com"
        required
      />
    </div>
    <div class="field">
      <label for="subject">Asunto</label>
      <input class="field__input" id="subject" name="subject" type="text" placeholder="Dolor sit amet" />
    </div>
    <div class="field">
      <label for="message">Mensaje</label>
      <textarea
        class="field__input"
        id="message"
        name="message"
        rows="5"
        placeholder="Consectetur adipiscing elit sed do eiusmod tempor incididunt..."
        required
      ></textarea>
    </div>
    <Button type="submit" tone="coral" size="lg">Enviar mensaje</Button>
  </form>

  <div class="contact-form__info">
    {
      details.map((d) => (
        <div class="info-block">
          <p class="info-block__label">{d.label}</p>
          <p class="info-block__value" set:html={d.value} />
        </div>
      ))
    }
    <div class="contact-form__socials">
      {
        socials.map((s) => (
          <a href="#" aria-label={s.label}>
            <img src={s.icon} alt="" width="36" height="36" />
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact-form {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    border-top: var(--border-base);
    border-bottom: var(--border-base);
  }

  .contact-form__form {
    background: var(--color-bg);
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.375rem;
    border-right: var(--border-base);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .field label {
    font-weight: var(--fw-bold);
    font-size: 0.875rem;
  }
  .field__input {
    border: var(--border-base);
    background: var(--color-bg);
    color: var(--color-ink);
    padding: 0.875rem 1rem;
    font-size: 0.9375rem;
    font-family: var(--font-body);
    resize: vertical;
    transition: box-shadow 0.1s ease, translate 0.1s ease;
  }
  .field__input::placeholder {
    color: var(--color-ink);
    opacity: 0.4;
  }
  .field__input:focus {
    outline: none;
    box-shadow: var(--shadow-md);
    translate: -2px -2px;
  }

  .contact-form__info {
    background: var(--color-ink);
    color: var(--color-bg);
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .info-block__label {
    font-weight: var(--fw-bold);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-coral-soft);
    margin: 0;
  }
  .info-block__value {
    font-size: 1.125rem;
    font-weight: var(--fw-semibold);
    line-height: 1.5;
    margin: 0;
  }

  .contact-form__socials {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    align-items: center;
  }
  .contact-form__socials a {
    display: flex;
  }

  @media (max-width: 768px) {
    .contact-form {
      grid-template-columns: 1fr;
    }
    .contact-form__form {
      border-right: none;
      border-bottom: var(--border-base);
    }
  }
</style>
