---
interface Props {
  href?: string;
  variant?: 'solid' | 'outline';
  tone?: 'coral' | 'gray' | 'ink';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  type?: 'button' | 'submit';
  class?: string;
}

const {
  href,
  variant = 'solid',
  tone = 'coral',
  size = 'md',
  type = 'button',
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'button';
const classes = ['btn', `btn--${variant}`, `btn--${tone}`, `btn--${size}`, className]
  .filter(Boolean)
  .join(' ');
---

<Tag class={classes} href={href} type={href ? undefined : type}>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    cursor: pointer;
    transition: translate var(--ease-hover), box-shadow var(--ease-hover);
    translate: 0 0;
    color: var(--color-ink);
  }

  /* Sizes */
  .btn--sm {
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    border: var(--border-base);
    box-shadow: var(--shadow-sm);
  }
  .btn--sm:hover {
    translate: -3px -3px;
    box-shadow: var(--shadow-sm-hover);
  }

  .btn--md {
    padding: 0.625rem 1.125rem;
    font-size: 0.875rem;
    border: var(--border-base);
    box-shadow: var(--shadow-lg);
  }
  .btn--md:hover {
    translate: -4px -4px;
    box-shadow: var(--shadow-xl-hover);
  }

  .btn--lg {
    padding: 1.125rem 2.25rem;
    font-size: 1.0625rem;
    border: var(--border-thick);
    box-shadow: var(--shadow-lg);
  }
  .btn--lg:hover {
    translate: -4px -4px;
    box-shadow: var(--shadow-xl-hover);
  }

  .btn--xl {
    padding: 1.375rem 2.75rem;
    font-size: 1.1875rem;
    border: var(--border-thick);
    box-shadow: var(--shadow-xl);
  }
  .btn--xl:hover {
    translate: -5px -5px;
    box-shadow: var(--shadow-xl-hover);
  }

  /* Tones (solid variant) */
  .btn--solid.btn--coral {
    background: var(--color-coral);
  }
  .btn--solid.btn--gray {
    background: var(--color-gray);
  }
  .btn--solid.btn--ink {
    background: var(--color-ink);
    color: var(--color-bg);
  }

  /* Outline variant: transparent, thinner shadow-less border, used on dark backgrounds */
  .btn--outline {
    background: transparent;
    border: var(--border-base);
    box-shadow: none;
  }
  .btn--outline.btn--ink {
    border-color: var(--color-bg);
    color: var(--color-bg);
  }
  .btn--outline:hover {
    translate: 0 0;
    box-shadow: none;
    opacity: 0.85;
  }
</style>
