---
import type { CardItem } from '@/types/cards';

interface Props {
  items: CardItem[];
  columns?: 2 | 3 | 4;
  shadowTone?: 'ink' | 'coral';
  borderWidth?: 'base' | 'thick';
  layout?: 'grid' | 'wrap';
}

const {
  items,
  columns = 3,
  shadowTone = 'ink',
  borderWidth = 'thick',
  layout = 'grid',
} = Astro.props;
---

<div class={layout === 'wrap' ? 'card-grid card-grid--wrap' : `card-grid card-grid--${columns}`}>
  {
    items.map((item) => (
      <div
        class={`icon-card icon-card--${shadowTone} icon-card--${borderWidth}`}
        style={`--card-bg:${item.bg ?? 'var(--color-bg)'}; --card-fg:${item.fg ?? 'var(--color-ink)'};`}
      >
        <div class="icon-card__badge" style={item.badge.bg ? `--badge-bg:${item.badge.bg}` : ''}>
          {item.badge.type === 'icon' ? (
            <img src={item.badge.value} alt="" width="26" height="26" />
          ) : (
            <span class="icon-card__number">{item.badge.value}</span>
          )}
        </div>
        <h3 class="icon-card__title">{item.title}</h3>
        <p class="icon-card__body">{item.body}</p>
      </div>
    ))
  }
</div>

<style>
  .card-grid {
    display: grid;
    gap: 1.625rem;
    max-width: var(--container-max);
    width: 100%;
  }
  .card-grid--2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .card-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .card-grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }
  .card-grid--wrap {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }
  .card-grid--wrap .icon-card {
    flex: 1 1 320px;
    max-width: 360px;
  }
  @media (max-width: 992px) {
    .card-grid--2,
    .card-grid--3,
    .card-grid--4 {
      grid-template-columns: 1fr;
    }
  }

  .icon-card {
    background: var(--card-bg);
    color: var(--card-fg);
    padding: 1.875rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: translate var(--ease-hover), box-shadow var(--ease-hover);
    translate: 0 0;
  }

  .icon-card--base {
    border: var(--border-base);
  }
  .icon-card--thick {
    border: var(--border-thick);
  }

  .icon-card--ink {
    box-shadow: var(--shadow-lg);
  }
  .icon-card--ink:hover {
    translate: -4px -4px;
    box-shadow: var(--shadow-lg-hover);
  }
  .icon-card--coral {
    box-shadow: 8px 8px 0 var(--color-coral);
  }
  .icon-card--coral:hover {
    translate: -4px -4px;
    box-shadow: 12px 12px 0 var(--color-coral);
  }

  .icon-card__badge {
    width: 3.5rem;
    height: 3.5rem;
    border: var(--border-base);
    background: var(--badge-bg, var(--color-coral));
    color: var(--color-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }

  .icon-card__number {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 1.5rem;
  }

  .icon-card__title {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 1.3125rem;
    line-height: 1.1;
    margin: 0;
  }

  .icon-card__body {
    font-size: 0.875rem;
    opacity: 0.8;
    line-height: 1.6;
    margin: 0;
  }
</style>
