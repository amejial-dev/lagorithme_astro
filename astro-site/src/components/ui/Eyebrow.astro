---
interface Props {
  tone?: 'coral' | 'outline' | 'muted';
  center?: boolean;
  class?: string;
}
const { tone = 'coral', center = false, class: className = '' } = Astro.props;
---

<div class:list={['eyebrow', `eyebrow--${tone}`, { 'eyebrow--center': center }, className]}>
  <slot />
</div>

<style>
  .eyebrow {
    font-weight: var(--fw-bold);
    font-size: 0.8125rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    width: fit-content;
    color: var(--color-coral);
    padding: 0;
  }

  .eyebrow--outline {
    border: var(--border-thin);
    border-color: var(--color-coral);
    padding: 0.375rem 1rem;
  }

  .eyebrow--center {
    align-self: center;
  }

  .eyebrow--muted {
    color: var(--color-gray);
  }
</style>
