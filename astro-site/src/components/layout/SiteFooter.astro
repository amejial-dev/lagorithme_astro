---
import { footerNav, socialLinks } from '@data/nav';
import '@styles/layout/footer.css';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__top container">
    <div class="site-footer__brand">
      <a href="/" class="site-footer__logo">
        <img src="/assets/images/lago-logo.svg" alt="Lagorithme" height="32" />
      </a>
      <p class="site-footer__tagline">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit sed do eiusmod.
      </p>
    </div>

    <div class="site-footer__col">
      <p class="site-footer__heading">Navegación</p>
      {footerNav.navegacion.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>

    <div class="site-footer__col">
      <p class="site-footer__heading">Recursos</p>
      {footerNav.recursos.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>

    <div class="site-footer__col">
      <p class="site-footer__heading">Legal</p>
      {footerNav.legal.map((label) => <span class="site-footer__legal">{label}</span>)}
    </div>
  </div>

  <div class="site-footer__bottom container">
    <p class="site-footer__copy">© {year} Lagorithme. Todos los derechos reservados.</p>
    <div class="site-footer__social">
      {
        socialLinks.map((s) => (
          <a href="#" aria-label={s.label}>
            <img src={s.icon} alt={s.label} width="30" height="30" />
          </a>
        ))
      }
    </div>
  </div>
</footer>
