---
import PlantillaBase from '@plantillas/PlantillaBase.astro';
import PortadaColaboradores from '@componentes/secciones/colaboradores/PortadaColaboradores.astro';
import RejillaColaboradores from '@componentes/secciones/colaboradores/RejillaColaboradores.astro';
import LlamadaFinal from '@componentes/secciones/compartido/LlamadaFinal.astro';
import { colaboradores } from '@datos/colaboradores';
import '@estilos/paginas/colaboradores.css';
---

<PlantillaBase
  titulo="Colaboradores"
  descripcion="Las organizaciones que ya trabajan con lagorithme."
  activa="/colaboradores"
>
  <PortadaColaboradores total={colaboradores.length} />

  <section class="seccion seccion--pila seccion--pila-con-borde">
    <RejillaColaboradores colaboradores={colaboradores} />
  </section>

  <LlamadaFinal
    titulo="¿Quieres que tu organización sea la siguiente?"
    subtitulo="Trabajamos con empresas públicas y privadas de cualquier sector."
    etiquetaPrincipal="Iniciar transformación digital"
    rutaPrincipal="/contacto"
  />
</PlantillaBase>
