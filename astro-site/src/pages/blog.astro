---
import PlantillaBase from '@plantillas/PlantillaBase.astro';
import Antetitulo from '@componentes/ui/Antetitulo.astro';
import RejillaBlog from '@componentes/secciones/blog/RejillaBlog.astro';
import LlamadaFinal from '@componentes/secciones/compartido/LlamadaFinal.astro';
import { articulos } from '@datos/blog';
import '@estilos/paginas/blog.css';
---

<PlantillaBase titulo="Blog" descripcion="Novedades y artículos de lagorithme." activa="/blog">
  <section class="portada-blog seccion">
    <Antetitulo centrado>Blog</Antetitulo>
    <h1 class="portada-blog__titulo">Lo que aprendemos construyendo software.</h1>
    <p class="portada-blog__subtitulo">
      Automatización, inteligencia artificial y datos, contados desde los proyectos reales.
    </p>
  </section>

  <section class="seccion seccion--pila">
    <RejillaBlog articulos={articulos} />
  </section>

  <LlamadaFinal
    titulo="El futuro de tu organización se programa hoy."
    subtitulo="Si algo de lo que leíste te suena a tu operación, hablemos."
    etiquetaPrincipal="Iniciar transformación digital"
    rutaPrincipal="/contacto"
  />
</PlantillaBase>
