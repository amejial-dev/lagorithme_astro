---
import PlantillaBase from '@plantillas/PlantillaBase.astro';
import IntroSeccion from '@componentes/ui/IntroSeccion.astro';
import RejillaTarjetasIcono from '@componentes/ui/RejillaTarjetasIcono.astro';
import Cita from '@componentes/ui/Cita.astro';
import PortadaProducto from '@componentes/secciones/productos/PortadaProducto.astro';
import RejillaBento from '@componentes/secciones/productos/RejillaBento.astro';
import LlamadaFinal from '@componentes/secciones/compartido/LlamadaFinal.astro';
import { servicios, pasos, elementosBento } from '@datos/productos';
import '@estilos/paginas/productos.css';
---

<PlantillaBase
  titulo="Servicios"
  descripcion="Desarrollo a la medida, automatización, inteligencia artificial y analítica de datos."
  activa="/productos"
>
  <PortadaProducto />

  <section class="seccion seccion--pila">
    <IntroSeccion
      titulo="Un solo aliado para toda la transformación"
      subtitulo="Del primer diagnóstico al software funcionando y evolucionando en tu operación."
    />
    <RejillaBento elementos={elementosBento} />
  </section>

  <section class="seccion seccion--pila">
    <IntroSeccion
      antetitulo="Servicios"
      titulo="Lo que hacemos por ti"
      subtitulo="Seis frentes que se combinan según lo que tu organización necesite resolver."
    />
    <RejillaTarjetasIcono elementos={servicios} columnas={3} tonoSombra="tinta" grosorBorde="grueso" />
  </section>

  <section class="franja-cita seccion">
    <Cita tema="oscura" autor="lagorithme">
      "Acompañamos el crecimiento de nuestros clientes con herramientas que evolucionan junto a
      ellos."
    </Cita>
  </section>

  <section class="seccion seccion--pila">
    <IntroSeccion
      titulo="Cómo trabajamos"
      subtitulo="Entregamos por partes, para que el valor llegue antes del cierre del proyecto."
    />
    <RejillaTarjetasIcono elementos={pasos} columnas={3} tonoSombra="tinta" grosorBorde="grueso" />
  </section>

  <LlamadaFinal
    titulo="¿Qué proceso te está frenando?"
    subtitulo="Cuéntanos cómo funciona hoy y te decimos qué se puede automatizar."
    etiquetaPrincipal="Iniciar transformación digital"
    rutaPrincipal="/contacto"
  />
</PlantillaBase>
