---
import EncabezadoSitio from '@componentes/estructura/EncabezadoSitio.astro';
import PieSitio from '@componentes/estructura/PieSitio.astro';
import CargadorPagina from '@componentes/estructura/CargadorPagina.astro';
import AvisoCookies from '@componentes/estructura/AvisoCookies.astro';
import '@estilos/variables.css';
import '@estilos/base.css';
import '@estilos/utilidades.css';

interface Props {
  titulo: string;
  descripcion?: string;
  activa?: string;
}

const {
  titulo,
  descripcion = 'lagorithme — software development, process automation and artificial intelligence for organizations in Colombia and Latin America.',
  activa = '',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={descripcion} />
    <link rel="icon" type="image/svg+xml" href="/assets/images/lago-logo.svg" />
    <!-- Las fuentes son autoalojadas (ver base.css) y se precargan: sin el
         preload, el navegador no las pide hasta toparse con el primer texto
         que las usa, y el cambio de fuente se ve a mitad de carga. -->
    <link
      rel="preload"
      href="/assets/fonts/sora-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preload" href="/assets/fonts/ibrand.otf" as="font" type="font/otf" crossorigin />
    <title>{titulo} · lagorithme</title>
  </head>
  <body>
    <CargadorPagina />
    <EncabezadoSitio activa={activa} />
    <main>
      <slot />
    </main>
    <PieSitio />
    <AvisoCookies />

    <script src="../scripts/animaciones.ts"></script>
  </body>
</html>
