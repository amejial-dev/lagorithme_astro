---
import PlantillaBase from '@plantillas/PlantillaBase.astro';
import Antetitulo from '@componentes/ui/Antetitulo.astro';
import FormularioContacto from '@componentes/secciones/contacto/FormularioContacto.astro';
import Mascota from '@componentes/ui/Mascota.astro';
import '@estilos/paginas/contacto.css';
---

<PlantillaBase
  titulo="Contact"
  descripcion="Let's talk about your project: write to us and we'll reply."
  activa="/contacto"
>
  <section class="portada-contacto seccion--ajustada-abajo">
    <Antetitulo centrado>Contact</Antetitulo>
    <h1 class="portada-contacto__titulo">Let's talk about your project.</h1>
    <p class="portada-contacto__subtitulo">
      Four fields and you're done. Tell us what you need and we'll reply with a proposal on
      where to start.
    </p>

    <Mascota
      pose="preguntando"
      ancho="180px"
      abajo="0"
      izquierda="6%"
      visibilidad="escritorio"
    />
  </section>

  <FormularioContacto />
</PlantillaBase>
