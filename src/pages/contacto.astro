---
import PlantillaBase from '@plantillas/PlantillaBase.astro';
import Antetitulo from '@componentes/ui/Antetitulo.astro';
import FormularioContacto from '@componentes/secciones/contacto/FormularioContacto.astro';
import Mascota from '@componentes/ui/Mascota.astro';
import '@estilos/paginas/contacto.css';
---

<PlantillaBase
  titulo="Contacto"
  descripcion="Hablemos de tu proyecto: escríbenos y te respondemos."
  activa="/contacto"
>
  <section class="portada-contacto seccion--ajustada-abajo">
    <Antetitulo centrado>Contacto</Antetitulo>
    <h1 class="portada-contacto__titulo">Hablemos de tu proyecto.</h1>
    <p class="portada-contacto__subtitulo">
      Cuatro campos y listo. Nos cuentas qué necesitas y te respondemos con una propuesta de
      por dónde empezar.
    </p>

    <Mascota
      pose="preguntando"
      ancho="180px"
      abajo="0"
      izquierda="6%"
      visibilidad="escritorio"
    />
  </section>

  <FormularioContacto />
</PlantillaBase>
