---
import PlantillaBase from "@plantillas/PlantillaBase.astro";
import BandaTrabajos from "@componentes/secciones/inicio/BandaTrabajos.astro";
import Antetitulo from "@componentes/ui/Antetitulo.astro";
import Boton from "@componentes/ui/Boton.astro";
import IntroSeccion from "@componentes/ui/IntroSeccion.astro";
import RejillaTarjetasIcono from "@componentes/ui/RejillaTarjetasIcono.astro";
import BloqueDividido from "@componentes/secciones/compartido/BloqueDividido.astro";
import LlamadaFinal from "@componentes/secciones/compartido/LlamadaFinal.astro";
import PortadaInicio from "@componentes/secciones/inicio/PortadaInicio.astro";
import RejillaCuatroTarjetas from "@componentes/secciones/inicio/RejillaCuatroTarjetas.astro";
import AdornoNeo from "@componentes/ui/AdornoNeo.astro";
import PortatilCodigo from "@componentes/ui/PortatilCodigo.astro";
import { tarjetasServicio, tarjetasPilares } from "@datos/inicio";
import "@estilos/paginas/inicio.css";
---

<PlantillaBase titulo="Inicio" activa="/">
  <PortadaInicio />

  <BandaTrabajos />

  <BloqueDividido
    orden="texto-medio"
    fondoTexto="var(--color-blanco)"
    fondoMedio="var(--color-azul)"
  >
    <Antetitulo>Desarrollo a la medida</Antetitulo>
    <h2 class="bloque-titulo">
      Software construido sobre tu operación, no sobre una plantilla.
    </h2>
    <p class="bloque-cuerpo">
      Levantamos tus procesos reales —con sus excepciones— y desarrollamos la
      solución que encaja con ellos, lista para crecer cuando la organización lo
      haga.
    </p>
    <Boton ruta="/productos" tono="gris" tamano="sm">Ver servicios</Boton>
    <AdornoNeo slot="medio" pieza="07" ancho="300px" arriba="-80px" izquierda="-70px" opacidad="0.16" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <BloqueDividido
    orden="medio-texto"
    fondoMedio="var(--color-principal)"
    fondoTexto="var(--color-fondo)"
    bordeIntermedio
  >
    <Antetitulo>Automatización de procesos</Antetitulo>
    <h2 class="bloque-titulo">
      Las tareas repetitivas dejan de consumir el día de tu equipo.
    </h2>
    <p class="bloque-cuerpo">
      Automatizamos flujos operativos y administrativos para que las horas se
      vayan en decidir, no en copiar datos de un sistema a otro.
    </p>
    <Boton ruta="/productos" tono="gris" tamano="sm">Cómo funciona</Boton>
    <AdornoNeo slot="medio" pieza="11" ancho="280px" abajo="-80px" derecha="-60px" opacidad="0.18" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <section class="franja-destacada seccion">
    <IntroSeccion
      titulo="Tres frentes, una misma operación"
      subtitulo="Desarrollo, automatización e inteligencia artificial trabajando sobre el mismo sistema."
    />
    <RejillaTarjetasIcono
      elementos={tarjetasServicio}
      columnas={3}
      tonoSombra="tinta"
      grosorBorde="base"
    />
    <img
      src="/assets/images/feature-section-border.svg"
      alt=""
      class="franja-destacada__esquina"
    />
  </section>

  <BloqueDividido
    orden="texto-medio"
    fondoTexto="var(--color-fondo)"
    fondoMedio="var(--color-tinta)"
  >
    <Antetitulo tono="atenuado">Inteligencia artificial</Antetitulo>
    <h2 class="bloque-titulo">
      IA dentro de tu organización y dentro del software que ya usas.
    </h2>
    <p class="bloque-cuerpo">
      No hace falta empezar de cero: integramos capacidades de inteligencia
      artificial en los sistemas que tu equipo ya conoce y utiliza todos los
      días.
    </p>
    <Boton ruta="/productos" tono="gris" tamano="sm">Descubrir</Boton>
    <AdornoNeo slot="medio" pieza="14" ancho="320px" arriba="-90px" derecha="-80px" opacidad="0.14" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <section class="franja-destacada seccion">
    <IntroSeccion
      titulo="Y todo lo que sostiene la operación"
      subtitulo="Analítica, datos, cumplimiento e integraciones con lo que ya tienes montado."
    />
    <RejillaCuatroTarjetas elementos={tarjetasPilares} />
  </section>

  <BloqueDividido
    orden="medio-texto"
    fondoMedio="var(--color-azul)"
    fondoTexto="var(--color-principal)"
  >
    <p class="bloque-antetitulo">Colombia y Latinoamérica</p>
    <h2 class="bloque-titulo">Pensamos en grande desde el primer código.</h2>
    <p class="bloque-cuerpo bloque-cuerpo--oscuro">
      Lo que hoy resuelve un área mañana sostiene la empresa completa. Por eso
      construimos sobre infraestructura robusta desde el día uno.
    </p>
    <Boton ruta="/nosotros" tono="gris" tamano="md">Conocer lagorithme</Boton>
    <!-- <img
      src="/assets/images/cta-corner-accent.svg"
      alt=""
      class="bloque-esquina"
    /> -->
    <AdornoNeo slot="medio" pieza="18" ancho="260px" abajo="-70px" izquierda="-60px" opacidad="0.16" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <BloqueDividido
    orden="texto-medio"
    fondoTexto="var(--color-fondo)"
    fondoMedio="var(--color-gris)"
  >
    <h2 class="bloque-titulo">
      Aliados estratégicos en el crecimiento de nuestros clientes.
    </h2>
    <p class="bloque-cuerpo">
      Software hospitalario, observatorios de datos ambientales, plataformas a
      la medida: acompañamos cada proyecto con herramientas que evolucionan
      junto a la organización.
    </p>
    <Boton ruta="/colaboradores" tono="gris" tamano="md"
      >Ver colaboradores</Boton
    >
    <AdornoNeo slot="medio" pieza="13" ancho="300px" arriba="-80px" izquierda="-70px" opacidad="0.30" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <LlamadaFinal
    titulo="El futuro de tu organización se programa hoy."
    subtitulo="Cuéntanos qué proceso te está frenando y te decimos por dónde empezar."
    etiquetaPrincipal="Iniciar transformación digital"
    rutaPrincipal="/contacto"
  />
</PlantillaBase>
