---
import PlantillaBase from "@plantillas/PlantillaBase.astro";
import BandaMetodo from "@componentes/secciones/inicio/BandaMetodo.astro";
import Antetitulo from "@componentes/ui/Antetitulo.astro";
import Boton from "@componentes/ui/Boton.astro";
import IntroSeccion from "@componentes/ui/IntroSeccion.astro";
import RejillaTarjetasIcono from "@componentes/ui/RejillaTarjetasIcono.astro";
import BloqueDividido from "@componentes/secciones/compartido/BloqueDividido.astro";
import LlamadaFinal from "@componentes/secciones/compartido/LlamadaFinal.astro";
import PortadaInicio from "@componentes/secciones/inicio/PortadaInicio.astro";
import RejillaCuatroTarjetas from "@componentes/secciones/inicio/RejillaCuatroTarjetas.astro";
import AdornoNeo from "@componentes/ui/AdornoNeo.astro";
import PortatilCodigo from "@componentes/ui/PortatilCodigo.astro";
import { tarjetasServicio, tarjetasPilares } from "@datos/inicio";
import "@estilos/paginas/inicio.css";
---

<PlantillaBase titulo="Home" activa="/">
  <PortadaInicio />

  <BandaMetodo />

  <BloqueDividido
    orden="texto-medio"
    fondoTexto="var(--color-blanco)"
    fondoMedio="var(--color-azul)"
  >
    <Antetitulo>Custom development</Antetitulo>
    <h2 class="bloque-titulo">
      Software built around your operation, not a template.
    </h2>
    <p class="bloque-cuerpo">
      We map your real processes —exceptions included— and build the solution
      that fits them, ready to grow when your organization does.
    </p>
    <Boton ruta="/productos" tono="gris" tamano="sm">View services</Boton>
    <AdornoNeo slot="medio" pieza="07" ancho="300px" arriba="-80px" izquierda="-70px" opacidad="0.16" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <BloqueDividido
    orden="medio-texto"
    fondoMedio="var(--color-principal)"
    fondoTexto="var(--color-fondo)"
    bordeIntermedio
  >
    <Antetitulo>Process automation</Antetitulo>
    <h2 class="bloque-titulo">
      Repetitive tasks stop eating up your team's day.
    </h2>
    <p class="bloque-cuerpo">
      We automate operational and administrative workflows so the hours go into
      deciding, not copying data from one system to another.
    </p>
    <Boton ruta="/productos" tono="gris" tamano="sm">How it works</Boton>
    <AdornoNeo slot="medio" pieza="11" ancho="280px" abajo="-80px" derecha="-60px" opacidad="0.18" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <section class="franja-destacada seccion">
    <IntroSeccion
      titulo="Three fronts, one operation"
      subtitulo="Development, automation and artificial intelligence working on the same system."
    />
    <RejillaTarjetasIcono
      elementos={tarjetasServicio}
      columnas={3}
      tonoSombra="tinta"
      grosorBorde="base"
    />
    <img
      src="/assets/images/feature-section-border.svg"
      alt=""
      class="franja-destacada__esquina"
    />
  </section>

  <BloqueDividido
    orden="texto-medio"
    fondoTexto="var(--color-fondo)"
    fondoMedio="var(--color-tinta)"
  >
    <Antetitulo tono="atenuado">Artificial intelligence</Antetitulo>
    <h2 class="bloque-titulo">
      AI inside your organization and inside the software you already use.
    </h2>
    <p class="bloque-cuerpo">
      No need to start from scratch: we integrate artificial intelligence
      capabilities into the systems your team already knows and uses every day.
    </p>
    <Boton ruta="/productos" tono="gris" tamano="sm">Discover</Boton>
    <AdornoNeo slot="medio" pieza="14" ancho="320px" arriba="-90px" derecha="-80px" opacidad="0.14" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <section class="franja-destacada seccion">
    <IntroSeccion
      titulo="And everything that holds the operation together"
      subtitulo="Analytics, data, compliance and integrations with what you already have in place."
    />
    <RejillaCuatroTarjetas elementos={tarjetasPilares} />
  </section>

  <BloqueDividido
    orden="medio-texto"
    fondoMedio="var(--color-azul)"
    fondoTexto="var(--color-principal)"
  >
    <p class="bloque-antetitulo">Colombia and Latin America</p>
    <h2 class="bloque-titulo">We think big from the first line of code.</h2>
    <p class="bloque-cuerpo bloque-cuerpo--oscuro">
      What solves one area today supports the whole company tomorrow. That's why
      we build on robust infrastructure from day one.
    </p>
    <Boton ruta="/nosotros" tono="gris" tamano="md">Get to know lagorithme</Boton>
    <!-- <img
      src="/assets/images/cta-corner-accent.svg"
      alt=""
      class="bloque-esquina"
    /> -->
    <AdornoNeo slot="medio" pieza="18" ancho="260px" abajo="-70px" izquierda="-60px" opacidad="0.16" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <BloqueDividido
    orden="texto-medio"
    fondoTexto="var(--color-fondo)"
    fondoMedio="var(--color-gris)"
  >
    <h2 class="bloque-titulo">
      Strategic allies in our clients' growth.
    </h2>
    <p class="bloque-cuerpo">
      Hospital software, environmental data observatories, custom platforms: we
      support every project with tools that evolve alongside the organization.
    </p>
    <Boton ruta="/clientes" tono="gris" tamano="md"
      >View clients</Boton
    >
    <AdornoNeo slot="medio" pieza="13" ancho="300px" arriba="-80px" izquierda="-70px" opacidad="0.30" />
    <PortatilCodigo slot="medio" />
  </BloqueDividido>

  <LlamadaFinal
    titulo="Your organization's future is coded today."
    subtitulo="Tell us which process is slowing you down and we'll tell you where to start."
    etiquetaPrincipal="Start your digital transformation"
    rutaPrincipal="/contacto"
  />
</PlantillaBase>
