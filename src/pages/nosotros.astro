---
import PlantillaBase from '@plantillas/PlantillaBase.astro';
import IntroSeccion from '@componentes/ui/IntroSeccion.astro';
import RejillaTarjetasIcono from '@componentes/ui/RejillaTarjetasIcono.astro';
import Cita from '@componentes/ui/Cita.astro';
import PortadaNosotros from '@componentes/secciones/nosotros/PortadaNosotros.astro';
import MisionVision from '@componentes/secciones/nosotros/MisionVision.astro';
import VitrinaDesfasada from '@componentes/secciones/nosotros/VitrinaDesfasada.astro';
import LlamadaFinal from '@componentes/secciones/compartido/LlamadaFinal.astro';
import { capacidades, valoresCorporativos, mision, vision } from '@datos/nosotros';
import '@estilos/paginas/nosotros.css';
---

<PlantillaBase
  titulo="About"
  descripcion="Who we are, what drives us and the values we build software with at lagorithme."
  activa="/nosotros"
>
  <PortadaNosotros />

  <section class="fila-capacidades seccion">
    <RejillaTarjetasIcono elementos={capacidades} columnas={4} tonoSombra="tinta" grosorBorde="grueso" />
  </section>

  <section class="seccion seccion--pila seccion--blanca">
    <IntroSeccion
      titulo="Mission & Vision"
      subtitulo="Where we're headed and what we commit to along the way."
    />
    <MisionVision
      mision={{
        etiqueta: 'Our mission',
        titulo: 'Driving the digital transformation of organizations in Colombia.',
        cuerpo: mision,
      }}
      vision={{
        etiqueta: 'Our vision',
        titulo: 'Leading technology innovation, from Colombia to the world.',
        cuerpo: vision,
      }}
    />
  </section>

  <section class="seccion seccion--pila seccion--blanca">
    <IntroSeccion
      antetitulo="Corporate values"
      titulo="What defines us"
      subtitulo="Five principles that run through every project we take on."
    />
    <RejillaTarjetasIcono elementos={valoresCorporativos} tonoSombra="tinta" grosorBorde="base" disposicion="tres-dos" />
  </section>

  <section class="cita-destacada seccion">
    <Cita tema="clara" autor="lagorithme">
      "Our focus is on efficiency, scalability and constant evolution, with the goal of being
      strategic allies in our clients' growth."
    </Cita>
  </section>

  <VitrinaDesfasada />
<!-- 
  <LlamadaFinal
    titulo="Hablemos de lo que quieres transformar."
    subtitulo="Cuéntanos cómo opera tu organización hoy y te proponemos por dónde empezar."
    etiquetaPrincipal="Iniciar transformación digital"
    rutaPrincipal="/contacto"
  /> -->
</PlantillaBase>
