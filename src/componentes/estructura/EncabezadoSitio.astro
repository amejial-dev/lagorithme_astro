---
import { enlacesNavegacion } from '@datos/navegacion';
import { usarTraducciones, rutaLocal, rutaOtroIdioma } from '@/i18n/utils';
import '@estilos/estructura/encabezado.css';

const { activa = '' } = Astro.props;

const locale = Astro.currentLocale;
const t = usarTraducciones(locale);
const rutaIdioma = rutaOtroIdioma(Astro.url.pathname, locale);
---

<header class="encabezado">
  <a href={rutaLocal('/', locale)} class="encabezado__marca">
    <img src="/assets/images/lago-logo.svg" alt="lagorithme" width="154" height="36" />
  </a>

  <div class="encabezado__contenedor">
    <nav class="encabezado__navegacion" aria-label={t('header.mainNav')}>
      {
        enlacesNavegacion.map((enlace) => (
          <a
            href={rutaLocal(enlace.ruta, locale)}
            class:list={['pastilla-nav', { 'pastilla-nav--activa': enlace.ruta === activa }]}
          >
            {t(enlace.clave)}
          </a>
        ))
      }
    </nav>
  </div>

  <div class="encabezado__acciones">
    <a href={rutaLocal('/contacto', locale)} class="encabezado__cta">{t('header.cta')}</a>
    <a href={rutaIdioma} class="encabezado__idioma" aria-label={t('header.langAria')}>
      {t('header.langLabel')}
    </a>
    <button
      type="button"
      id="boton-menu"
      class="encabezado__boton-menu"
      aria-expanded="false"
      aria-controls="navegacion-movil"
      aria-label={t('header.openMenu')}
    >
      <span class="encabezado__barra"></span>
      <span class="encabezado__barra"></span>
      <span class="encabezado__barra"></span>
    </button>
  </div>

  <nav id="navegacion-movil" class="encabezado__navegacion-movil" aria-label={t('header.mobileNav')}>
    {
      enlacesNavegacion.map((enlace) => (
        <a
          href={rutaLocal(enlace.ruta, locale)}
          class:list={['pastilla-nav', { 'pastilla-nav--activa': enlace.ruta === activa }]}
        >
          {t(enlace.clave)}
        </a>
      ))
    }
  </nav>
</header>

<script src="../../scripts/encabezado-sitio.js"></script>

<style>
  /* Botón de cambio de idioma, junto al CTA. Mismo lenguaje neobrutalista
     que el resto: borde fino, sombra dura y desplazamiento al hover. */
  .encabezado__idioma {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-family: var(--fuente-cuerpo);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-2xs);
    letter-spacing: 0.5px;
    line-height: 1;
    color: var(--color-tinta);
    background: var(--color-fondo);
    border: var(--borde-fino);
    box-shadow: var(--sombra-sm);
    padding: 0.45rem 0.7rem;
    transition: translate var(--transicion-hover), box-shadow var(--transicion-hover);
    translate: 0 0;
  }
  .encabezado__idioma:hover {
    translate: -2px -2px;
    box-shadow: var(--sombra-sm-hover);
    color: var(--color-tinta);
  }
</style>
