---
/**
 * El portátil que acompaña al visitante por toda la portada.
 *
 * Es uno solo, fijo a media altura de la ventana, y va cambiando de lado
 * para caer siempre sobre el panel de medios del bloque que se esté
 * mirando. Al llegar a las secciones de tarjetas —que no tienen panel— se
 * desvanece, y vuelve a aparecer en el bloque siguiente.
 *
 * Quién manda sobre él: scripts/portatil-codigo.ts. Este archivo solo pone
 * el contenedor y su posición de partida.
 *
 * Va por debajo del encabezado (z-index 50) y no intercepta el ratón, para
 * que no se coma clics de la columna de texto que tiene al lado.
 */
import PortatilCodigo from '@componentes/ui/PortatilCodigo.astro';
---

<div class="portatil-viajero" data-portatil-viajero aria-hidden="true">
  <PortatilCodigo />
</div>

<style>
  .portatil-viajero {
    position: fixed;

    /* Ojo: ni `top: 50%` ni `translate` aquí. GSAP absorbe la propiedad CSS
       `translate` dentro de su propia matriz al animar, y el centrado se
       perdía sin dejar rastro en el CSS. La posición vertical la fija el
       script en píxeles, que además es lo que necesita para recortarla
       contra el panel. */
    top: 0;
    left: 0;

    /* Ocupa media ventana y centra dentro: así "cambiar de lado" es
       moverlo 50vw, sin recalcular anchos ni márgenes. */
    width: 50vw;
    display: flex;
    align-items: center;
    justify-content: center;

    z-index: 20;
    pointer-events: none;

    /* Arranca invisible: la portada no es un bloque partido. Lo enciende
       el script en cuanto uno entra en el centro de la ventana. */
    opacity: 0;
  }

  .portatil-viajero :global(.portatil) {
    width: 78%;
    max-width: 32rem;
  }

  /* Apilado no hay dos columnas sobre las que volar, y un elemento fijo
     taparía el texto. Ahí manda la instancia en flujo del primer panel. */
  @media (max-width: 768px) {
    .portatil-viajero {
      display: none;
    }
  }
</style>
