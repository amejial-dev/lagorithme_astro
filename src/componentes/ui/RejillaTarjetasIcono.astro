---
const {
  elementos,
  columnas = 3,
  tonoSombra = 'tinta',
  grosorBorde = 'grueso',
  disposicion = 'rejilla',
} = Astro.props;
---

<div
  class={disposicion === 'rejilla'
    ? `rejilla-tarjetas rejilla-tarjetas--${columnas}`
    : `rejilla-tarjetas rejilla-tarjetas--${disposicion}`}
>
  {
    elementos.map((elemento) => (
      <div
        class={`tarjeta-icono tarjeta-icono--${tonoSombra} tarjeta-icono--${grosorBorde}`}
        style={`--tarjeta-fondo:${elemento.fondo ?? 'var(--color-fondo)'}; --tarjeta-texto:${elemento.texto ?? 'var(--color-tinta)'};`}
      >
        <div
          class={`tarjeta-icono__insignia tarjeta-icono__insignia--${elemento.insignia.tipo}`}
          style={elemento.insignia.fondo ? `--insignia-fondo:${elemento.insignia.fondo}` : ''}
        >
          {elemento.insignia.tipo === 'icono' ? (
            <img src={elemento.insignia.valor} alt="" width="56" height="56" />
          ) : (
            <span class="tarjeta-icono__numero">{elemento.insignia.valor}</span>
          )}
        </div>
        <h3 class="tarjeta-icono__titulo">{elemento.titulo}</h3>
        <p class="tarjeta-icono__cuerpo">{elemento.cuerpo}</p>
      </div>
    ))
  }
</div>

<style>
  .rejilla-tarjetas {
    display: grid;
    gap: 1.625rem;
    max-width: var(--contenedor-max);
    width: 100%;
    margin-inline: auto;
  }
  .rejilla-tarjetas--2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .rejilla-tarjetas--3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .rejilla-tarjetas--4 {
    grid-template-columns: repeat(4, 1fr);
  }
  .rejilla-tarjetas--flujo {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }
  .rejilla-tarjetas--flujo .tarjeta-icono {
    flex: 1 1 320px;
    max-width: 360px;
  }

  /* Rejilla de seis pistas: cada tarjeta ocupa dos, y la cuarta arranca en
     la pista 2, lo que centra la fila de abajo. */
  .rejilla-tarjetas--tres-dos {
    grid-template-columns: repeat(6, 1fr);
  }
  .rejilla-tarjetas--tres-dos .tarjeta-icono {
    grid-column: span 2;
  }
  .rejilla-tarjetas--tres-dos .tarjeta-icono:nth-child(4) {
    grid-column: 2 / span 2;
  }

  @media (max-width: 992px) {
    .rejilla-tarjetas--2,
    .rejilla-tarjetas--3 {
      grid-template-columns: 1fr;
    }

    /* Cuatro tarjetas en columna única era un tubo larguísimo: mejor 2×2
       hasta el apilado de móvil. */
    .rejilla-tarjetas--4 {
      grid-template-columns: 1fr 1fr;
    }

    /* El tres-dos pasa a 2+2+1, con la última a lo ancho. */
    .rejilla-tarjetas--tres-dos {
      grid-template-columns: 1fr 1fr;
    }
    .rejilla-tarjetas--tres-dos .tarjeta-icono,
    .rejilla-tarjetas--tres-dos .tarjeta-icono:nth-child(4) {
      grid-column: auto;
    }
    .rejilla-tarjetas--tres-dos .tarjeta-icono:nth-child(5) {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 576px) {
    .rejilla-tarjetas--4,
    .rejilla-tarjetas--tres-dos {
      grid-template-columns: 1fr;
    }
    .rejilla-tarjetas--tres-dos .tarjeta-icono:nth-child(5) {
      grid-column: auto;
    }
  }

  .tarjeta-icono {
    background: var(--tarjeta-fondo);
    color: var(--tarjeta-texto);

    /* Ceñido al contenido: con 1.875rem de padding y 1rem de gap la caja
       doblaba en aire al texto que lleva dentro. */
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: translate var(--transicion-hover), box-shadow var(--transicion-hover);
    translate: 0 0;
  }

  .tarjeta-icono--base {
    border: var(--borde-base);
  }
  .tarjeta-icono--grueso {
    border: var(--borde-grueso);
  }

  .tarjeta-icono--tinta {
    box-shadow: var(--sombra-lg);
  }
  .tarjeta-icono--tinta:hover {
    translate: 4px 4px;
    box-shadow: var(--sombra-lg-hover);
  }
  .tarjeta-icono--principal {
    box-shadow: 4px 4px 0 var(--color-principal);
  }
  .tarjeta-icono--principal:hover {
    translate: 4px 4px;
    box-shadow: none;
  }

  .tarjeta-icono__insignia {
    width: 3rem;
    height: 3rem;
    color: var(--color-tinta);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tarjeta-icono__insignia--numero {
    border: var(--borde-base);
    background: var(--insignia-fondo, var(--color-principal));
    box-shadow: var(--sombra-sm);
  }

  .tarjeta-icono__insignia--icono img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .tarjeta-icono__numero {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-h6);
  }

  .tarjeta-icono__titulo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-xl);
    line-height: 1.15;
    margin: 0;
  }

  .tarjeta-icono__cuerpo {
    font-size: var(--texto-xs);
    opacity: 0.8;
    line-height: 1.6;
    margin: 0;
  }
</style>
