---
const { tono = 'principal', centrado = false, class: clase = '' } = Astro.props;
---

<div class:list={['antetitulo', `antetitulo--${tono}`, { 'antetitulo--centrado': centrado }, clase]}>
  <slot />
</div>

<style>
  .antetitulo {
    font-weight: var(--peso-negrita);
    font-size: var(--texto-2xs);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    width: fit-content;
    color: var(--color-principal);
    padding: 0;
  }

  .antetitulo--contorno {
    border: var(--borde-fino);
    border-color: var(--color-principal);
    padding: 0.375rem 1rem;
  }

  .antetitulo--centrado {
    align-self: center;
  }

  .antetitulo--atenuado {
    color: var(--color-gris);
  }
</style>
