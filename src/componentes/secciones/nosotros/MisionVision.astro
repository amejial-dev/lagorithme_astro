---
const { mision, vision } = Astro.props;
const elementos = [mision, vision];
---

<div class="rejilla-mv">
  {
    elementos.map((elemento) => (
      <div class="tarjeta-mv">
        <div class="tarjeta-mv__icono">
          <img src="/assets/icons/bookmark.svg" alt="" width="52" height="52" />
        </div>
        <p class="tarjeta-mv__etiqueta">{elemento.etiqueta}</p>
        <h3 class="tarjeta-mv__titulo">{elemento.titulo}</h3>
        <p class="tarjeta-mv__cuerpo">{elemento.cuerpo}</p>
      </div>
    ))
  }
</div>

<style>
  .rejilla-mv {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem;
    max-width: 1100px;
    width: 100%;
  }

  /* Blancas y no coral: el par coral era un bloque de color muy pesado y
     competía con el resto de la página. El borde grueso y la sombra dura
     las despegan de la banda blanca; el color queda en la etiqueta. */
  .tarjeta-mv {
    border: var(--borde-base);
    background: var(--color-blanco);
    color: var(--color-tinta);
    box-shadow: var(--sombra-lg);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tarjeta-mv__icono {
    width: 3.25rem;
    height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tarjeta-mv__icono img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* El acento de marca de la tarjeta: pastilla coral con borde y sombra
     pequeña, el mismo lenguaje de las insignias del resto del sitio. */
  .tarjeta-mv__etiqueta {
    align-self: flex-start;
    background: var(--color-principal);
    border: var(--borde-fino);
    box-shadow: var(--sombra-sm);
    padding: 0.35rem 0.75rem;
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-sm);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }

  .tarjeta-mv__titulo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-h6);
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin: 0;
  }

  .tarjeta-mv__cuerpo {
    font-size: var(--texto-sm);
    opacity: 0.8;
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 768px) {
    .rejilla-mv {
      grid-template-columns: 1fr;
    }
  }
</style>
