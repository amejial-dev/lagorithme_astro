---
import Boton from '@componentes/ui/Boton.astro';
import AdornoNeo from '@componentes/ui/AdornoNeo.astro';
import { usarTraducciones, rutaLocal } from '@/i18n/utils';

const locale = Astro.currentLocale;
const t = usarTraducciones(locale);

const {
  titulo,
  subtitulo,
  etiquetaPrincipal,
  rutaPrincipal,
  etiquetaSecundaria = t('final.secondary'),
  rutaSecundaria = '/contacto',
} = Astro.props;
---

<section class="llamada-final seccion">
  <AdornoNeo pieza="15" ancho="300px" arriba="-90px" izquierda="-90px" opacidad="0.07" />
  <AdornoNeo pieza="09" ancho="260px" abajo="-80px" derecha="-70px" opacidad="0.07" />

  <h2 class="llamada-final__titulo">{titulo}</h2>
  <p class="llamada-final__subtitulo">{subtitulo}</p>
  <div class="llamada-final__acciones">
    {
      etiquetaPrincipal && rutaPrincipal && (
        <Boton
          ruta={rutaLocal(rutaPrincipal, locale)}
          variante="solido"
          tono="gris"
          tamano="xl"
          class="llamada-final__cta"
        >
          {etiquetaPrincipal}
        </Boton>
      )
    }
    <Boton ruta={rutaLocal(rutaSecundaria, locale)} variante="contorno" tamano="md">
      {etiquetaSecundaria}
    </Boton>
  </div>
</section>

<style>
  .llamada-final {
    position: relative;
    overflow: hidden;
    background: var(--color-principal);
    color: var(--color-tinta);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.375rem;
    padding-top: 6.25rem;
    padding-bottom: 6.25rem;

    /* Pantalla completa de verdad: al ir al fondo de la página el encabezado
       es un overlay sticky y no ocupa lugar aquí, así que no se descuenta. */
    min-height: 100svh;
  }

  /* En pantallas muy bajas el alto mínimo estorba más de lo que ayuda. */
  @media (max-height: 480px) {
    .llamada-final {
      min-height: 0;
    }
  }

  .llamada-final__titulo,
  .llamada-final__subtitulo,
  .llamada-final__acciones {
    position: relative;
    z-index: 1;
  }

  .llamada-final__titulo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-h3);
    line-height: 1.1;
    letter-spacing: -1px;
    max-width: 760px;
    margin: 0;
  }

  .llamada-final__subtitulo {
    font-size: var(--texto-lg);
    opacity: 0.7;
    max-width: 520px;
    margin: 0;
  }

  .llamada-final__acciones {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    margin-top: 0.625rem;

    /* El CTA principal se estira a lo ancho de este contenedor; el ancho
       máximo es lo que hace que ocupe la banda como el hero de inicio. */
    width: 100%;
    max-width: 720px;
    margin-inline: auto;
  }

  /* El botón vive dentro del componente Boton, así que su clase no lleva el
     scope de esta sección: hay que alcanzarla con :global. */
  .llamada-final__acciones :global(.llamada-final__cta) {
    width: 100%;
  }
</style>
