---
/**
 * Sección partida en dos columnas: un panel de texto junto a un panel de
 * medios. Se reutiliza en toda la portada para cada bloque alternado de
 * imagen/texto.
 */
const {
  orden = 'texto-medio',
  fondoTexto = 'var(--color-fondo)',
  fondoMedio = 'var(--color-azul)',
  bordeIntermedio = false,
} = Astro.props;
---

<div class={`bloque-dividido bloque-dividido--${orden}`}>
  <div
    class:list={[
      'bloque-dividido__contenido',
      { 'bloque-dividido__contenido--con-borde': bordeIntermedio },
    ]}
    style={`background:${fondoTexto};`}
  >
    <div class="bloque-dividido__bloque">
      <slot />
    </div>
  </div>
  <div class="bloque-dividido__medio" style={`background:${fondoMedio};`}>
    <slot name="medio" />
  </div>
</div>

<style>
  .bloque-dividido {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: var(--borde-base);
  }

  .bloque-dividido--medio-texto {
    grid-template-areas: 'medio contenido';
  }
  .bloque-dividido--medio-texto .bloque-dividido__medio {
    grid-area: medio;
  }
  .bloque-dividido--medio-texto .bloque-dividido__contenido {
    grid-area: contenido;
  }

  .bloque-dividido__contenido {
    color: var(--color-tinta);

    /* Mismo alto que el panel del portátil. La fila del grid ya iguala a
       los dos por el más alto, pero dejarlo escrito aquí documenta la
       intención y aguanta si alguien cambia el align-items. */
    min-height: 920px;

    padding: 5.5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;

    /* Centra el bloque dentro del panel: al hacer zoom out el panel crece,
       pero el contenido se queda en el medio en vez de estirarse de borde
       a borde. */
    align-items: center;

    position: relative;
  }

  /* Tope de ancho del contenido. No es un ancho fijo: por debajo de este
     valor el bloque ocupa lo que haya, así que en pantallas normales nada
     cambia. Solo actúa cuando el panel se vuelve demasiado ancho. */
  .bloque-dividido__bloque {
    width: 100%;
    max-width: 34rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* Ritmo vertical: el gap uniforme dejaba los cuatro elementos igual de
     apretados. El antetítulo pertenece al titular, así que se le pega; y el
     botón es la acción, así que se separa para que se lea como paso aparte
     y no como una línea más del párrafo. */
  .bloque-dividido__bloque :global(.antetitulo),
  .bloque-dividido__bloque :global(.bloque-antetitulo) {
    margin-bottom: -0.875rem;
  }

  .bloque-dividido__bloque :global(.boton) {
    margin-top: 0.75rem;
  }
  .bloque-dividido__contenido--con-borde {
    border-left: var(--borde-base);
  }

  .bloque-dividido__medio {
    /* Alto del panel donde va el portátil. min-height y no height: si algún
       día el texto de la columna vecina crece más que esto, la fila lo
       acompaña en vez de desbordarse. */
    min-height: 920px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .bloque-dividido__medio > :global(img) {
    max-width: 80%;
    height: auto;
    display: block;
  }

  /* Entre el apilado y el escritorio las dos columnas son estrechas, y 920px
     de alto las dejaría como dos torres. Se baja el alto en ese tramo. */
  @media (max-width: 1100px) {
    .bloque-dividido__contenido,
    .bloque-dividido__medio {
      min-height: 560px;
    }
  }

  @media (max-width: 768px) {
    .bloque-dividido,
    .bloque-dividido--medio-texto {
      grid-template-columns: 1fr;
      grid-template-areas: none;
    }
    .bloque-dividido__contenido {
      /* Apilado, el texto ocupa lo que necesite: forzarle un alto solo
         mete aire muerto entre el texto y la imagen. */
      min-height: 0;
      padding: 3rem 1.75rem;
      border-left: none !important;
      border-top: var(--borde-base);
      order: 2;
    }
    .bloque-dividido__medio {
      min-height: 260px;
      order: 1;
    }
  }
</style>
