---
import { colaboradores } from '@datos/colaboradores';
import AdornoNeo from '@componentes/ui/AdornoNeo.astro';

/*
  Ocupa el hueco de la prueba, justo debajo de la portada. La jerarquía
  está invertida a propósito: manda el TRABAJO y el cliente baja a firma.
  Un nombre suelto no prueba nada ante alguien que llega frío —y no
  tenemos sus logos—, pero "software hospitalario" lo entiende cualquiera.

  Lee de los mismos datos que /colaboradores para que no se desincronicen.
*/
---

<section class="banda-trabajos">
  <AdornoNeo pieza="06" ancho="260px" abajo="-90px" izquierda="-60px" opacidad="0.08" />
  <AdornoNeo pieza="10" ancho="180px" arriba="30%" derecha="-60px" opacidad="0.06" />

  <div class="banda-trabajos__contenedor contenedor">
    <p class="banda-trabajos__etiqueta">Ahora mismo estamos construyendo</p>

    <ul class="banda-trabajos__lista">
      {
        colaboradores.map((colaborador) => (
          <li class="banda-trabajos__elemento">
            <h2 class="banda-trabajos__trabajo">{colaborador.trabajo}</h2>
            <p class="banda-trabajos__resumen">{colaborador.resumen}</p>
            <p class="banda-trabajos__firma">
              <span class="banda-trabajos__cliente">{colaborador.nombre}</span>
              <span class="banda-trabajos__sector">{colaborador.sector}</span>
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .banda-trabajos {
    position: relative;
    overflow: hidden;
    background: var(--color-tinta);
    color: var(--color-fondo);
    border-bottom: var(--borde-base);
    padding: clamp(3rem, 6vw, 4.5rem) var(--seccion-espaciado-x);
  }

  .banda-trabajos__contenedor {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .banda-trabajos__etiqueta {
    font-weight: var(--peso-negrita);
    font-size: var(--texto-3xs);
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-gris);
    margin: 0;
  }

  .banda-trabajos__lista {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  /* La regla coral superior es el único adorno de la sección: estructura
     las tres columnas y trae el color de marca sin competir con el texto. */
  .banda-trabajos__elemento {
    border-top: 3px solid var(--color-principal);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .banda-trabajos__trabajo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-h5);
    line-height: 1.1;
    letter-spacing: -0.5px;
    margin: 0;
    text-wrap: balance;
  }

  .banda-trabajos__resumen {
    font-size: var(--texto-sm);
    line-height: 1.5;
    opacity: 0.7;
    margin: 0;
  }

  .banda-trabajos__firma {
    margin: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .banda-trabajos__cliente {
    font-weight: var(--peso-negrita);
    font-size: var(--texto-sm);
  }

  .banda-trabajos__sector {
    font-size: var(--texto-3xs);
    letter-spacing: 0.5px;
    color: var(--color-gris);
  }

  @media (max-width: 768px) {
    .banda-trabajos__lista {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
