---
import AdornoNeo from '@componentes/ui/AdornoNeo.astro';

/*
  Ocupa el hueco de la prueba social, justo bajo la portada. Sin productos
  lanzados ni logos que enseñar, lo que sí se puede probar es el método:
  cuatro pasos concretos que transmiten proceso y seriedad sin reclamar
  una cartera que aún no existe. Sustituye a la antigua banda de trabajos
  con firma de cliente (decisión debatida el 24/07/2026).
*/
const pasos = [
  {
    numero: '01',
    titulo: 'Discovery',
    cuerpo: 'We map your real operation, exceptions and all.',
  },
  {
    numero: '02',
    titulo: 'Design',
    cuerpo: 'We define the solution that fits your processes.',
  },
  {
    numero: '03',
    titulo: 'Development',
    cuerpo: 'Short cycles, with deliverables you can see and test.',
  },
  {
    numero: '04',
    titulo: 'Evolution',
    cuerpo: 'The software grows at the pace of your organization.',
  },
];
---

<section class="banda-metodo">
  <AdornoNeo pieza="06" ancho="260px" abajo="-90px" izquierda="-60px" opacidad="0.08" />
  <AdornoNeo pieza="10" ancho="180px" arriba="30%" derecha="-60px" opacidad="0.06" />

  <div class="banda-metodo__contenedor contenedor">
    <p class="banda-metodo__etiqueta">How we work</p>

    <ol class="banda-metodo__pasos">
      {
        pasos.map((paso) => (
          <li class="banda-metodo__paso">
            <span class="banda-metodo__numero">{paso.numero}</span>
            <h2 class="banda-metodo__titulo">{paso.titulo}</h2>
            <p class="banda-metodo__cuerpo">{paso.cuerpo}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .banda-metodo {
    position: relative;
    overflow: hidden;
    background: var(--color-tinta);
    color: var(--color-fondo);
    border-bottom: var(--borde-base);
    padding: clamp(3rem, 6vw, 4.5rem) var(--seccion-espaciado-x);
  }

  .banda-metodo__contenedor {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 3vw, 2.5rem);
  }

  .banda-metodo__etiqueta {
    margin: 0;
    font-weight: var(--peso-negrita);
    font-size: var(--texto-3xs);
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-principal-suave);
  }

  .banda-metodo__pasos {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .banda-metodo__paso {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  /* Ficha de número al estilo de las insignias del sitio. La sombra es
     azul profundo y no tinta: sobre la banda de tinta una sombra de tinta
     no existe. */
  .banda-metodo__numero {
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-principal);
    color: var(--color-tinta);
    border: var(--borde-base);
    box-shadow: 4px 4px 0 var(--color-azul);
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
  }

  .banda-metodo__titulo {
    margin: 0;
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-xl);
    color: var(--color-blanco);
  }

  .banda-metodo__cuerpo {
    margin: 0;
    font-size: var(--texto-xs);
    line-height: 1.6;
    opacity: 0.75;
  }

  @media (max-width: 992px) {
    .banda-metodo__pasos {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 576px) {
    .banda-metodo__pasos {
      grid-template-columns: 1fr;
    }
  }
</style>
