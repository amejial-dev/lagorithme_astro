---
import Antetitulo from '@componentes/ui/Antetitulo.astro';
import AdornoNeo from '@componentes/ui/AdornoNeo.astro';
import Mascota from '@componentes/ui/Mascota.astro';
import { usarTraducciones } from '@/i18n/utils';

const { total } = Astro.props;
const totalFormateado = String(total).padStart(2, '0');

const t = usarTraducciones(Astro.currentLocale);
---

<section class="portada-clientes">
  <div class="portada-clientes__contenido">
    <AdornoNeo pieza="04" ancho="280px" abajo="-80px" derecha="-70px" opacidad="0.08" />

    <Antetitulo tono="contorno">{t('clients.hero.eyebrow')}</Antetitulo>
    <h1 class="portada-clientes__titulo">{t('clients.hero.title')}</h1>
    <p class="portada-clientes__subtitulo">{t('clients.hero.subtitle')}</p>
  </div>
  <div class="portada-clientes__panel">
    <AdornoNeo pieza="16" ancho="260px" arriba="-70px" derecha="-60px" opacidad="0.35" />

    <p class="portada-clientes__conteo">{totalFormateado}</p>
    <p class="portada-clientes__etiqueta">{t('clients.hero.countLabel')}</p>

    <!-- Abajo a la izquierda, señalando hacia la cifra que corona el panel. -->
  </div>
</section>

<style>
  .portada-clientes {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    border-bottom: var(--borde-base);
  }

  .portada-clientes__contenido {
    position: relative;
    overflow: hidden;
    background: var(--color-tinta);
    color: var(--color-fondo);
    padding: 5.25rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.375rem;
  }

  .portada-clientes__titulo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-h2);
    line-height: 1.02;
    letter-spacing: -1.5px;
    max-width: 36rem;
    margin: 0;
  }

  .portada-clientes__subtitulo {
    font-size: var(--texto-lg);
    max-width: 520px;
    opacity: 0.7;
    line-height: 1.6;
    margin: 0;
  }

  .portada-clientes__panel {
    position: relative;
    overflow: hidden;
    background: var(--color-principal);
    border-left: var(--borde-base);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 2.75rem;
    min-height: 21.25rem;
  }

  .portada-clientes__conteo {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-display);
    line-height: 1;
    letter-spacing: -4px;
    color: var(--color-tinta);
    margin: 0;
  }

  .portada-clientes__etiqueta {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-base);
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-tinta);
    margin: 0;
  }

  @media (max-width: 768px) {
    .portada-clientes {
      grid-template-columns: 1fr;
    }
    .portada-clientes__panel {
      border-left: none;
      border-top: var(--borde-base);
    }
  }
</style>
