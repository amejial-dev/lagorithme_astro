---
const { clientes } = Astro.props;
---

<div class="rejilla-clientes">
  {
    clientes.map((cliente) => (
      <article class="tarjeta-cliente">
        <div
          class="tarjeta-cliente__retrato"
          style={`--retrato-fondo:${cliente.fondo}; --color-inicial:${cliente.colorInicial};`}
        >
          <span class="tarjeta-cliente__inicial">{cliente.inicial}</span>
          <span class="tarjeta-cliente__etiqueta">{cliente.etiqueta}</span>
        </div>
        <div class="tarjeta-cliente__cuerpo">
          <div>
            <h3 class="tarjeta-cliente__nombre">{cliente.nombre}</h3>
            <p class="tarjeta-cliente__sector">{cliente.sector}</p>
          </div>
          <p class="tarjeta-cliente__descripcion">{cliente.descripcion}</p>
        </div>
      </article>
    ))
  }
</div>

<style>
  .rejilla-clientes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: var(--contenedor-max);
    width: 100%;
  }

  .tarjeta-cliente {
    border: var(--borde-grueso);
    background: var(--color-fondo);
    box-shadow: var(--sombra-xl);
    display: flex;
    flex-direction: column;
    transition: translate var(--transicion-hover), box-shadow var(--transicion-hover);
    translate: 0 0;
  }
  .tarjeta-cliente:hover {
    translate: 4px 4px;
    box-shadow: var(--sombra-xl-hover);
  }

  .tarjeta-cliente__retrato {
    background: var(--retrato-fondo);
    border-bottom: var(--borde-grueso);
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .tarjeta-cliente__inicial {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-display);
    line-height: 1;
    color: var(--color-inicial);
  }

  .tarjeta-cliente__etiqueta {
    position: absolute;
    top: 1rem;
    right: 1rem;
    border: var(--borde-fino);
    background: var(--color-fondo);
    color: var(--color-tinta);
    font-size: var(--texto-4xs);
    font-weight: var(--peso-negrita);
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
  }

  .tarjeta-cliente__cuerpo {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tarjeta-cliente__nombre {
    font-family: var(--fuente-titulos);
    font-weight: var(--peso-negrita);
    font-size: var(--texto-h6);
    line-height: 1.1;
    margin: 0;
  }

  .tarjeta-cliente__sector {
    font-weight: var(--peso-negrita);
    font-size: var(--texto-2xs);
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-principal);
    margin: 0.25rem 0 0;
  }

  .tarjeta-cliente__descripcion {
    font-size: var(--texto-xs);
    opacity: 0.75;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 992px) {
    .rejilla-clientes {
      grid-template-columns: 1fr;
    }
  }
</style>
