# Copia este archivo como `.env` para probar el envío del formulario en
# local (astro dev). En producción, estas mismas variables se configuran
# en Netlify: Site configuration → Environment variables.
#
# El .env real está en .gitignore: NUNCA subir credenciales al repositorio.

# Si la cuenta Zoho es de la región europea, usar smtp.zoho.eu
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465

# Cuenta Zoho completa que envía los correos
SMTP_USER=web@lagorithme.com

# Contraseña de APLICACIÓN de Zoho (no la contraseña de la cuenta).
# Se genera en https://accounts.zoho.com → Seguridad → App Passwords
# y requiere tener activada la verificación en dos pasos.
SMTP_PASS=xxxxxxxxxxxx

# A dónde llegan las solicitudes de contacto
CONTACTO_DESTINO=dtorradoc@lagorithme.com
