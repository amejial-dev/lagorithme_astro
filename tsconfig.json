{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@componentes/*": ["src/componentes/*"],
      "@plantillas/*": ["src/plantillas/*"],
      "@datos/*": ["src/datos/*"],
      "@estilos/*": ["src/estilos/*"],
      "@tipos/*": ["src/tipos/*"]
    }
  }
}
